{
  "version": 1,
  "name": "Vietnamese banking regulation starter ontology",
  "description": "An editable, deliberately small ontology for legal and banking PDF retrieval.",
  "entity_types": {
    "LegalDocument": ["Law", "Decree", "Circular", "Decision", "Resolution", "OtherLegalDocument"],
    "LegalSection": ["Chapter", "Section", "Article", "Clause", "Point"],
    "Actor": ["Authority", "FinancialInstitution", "Organization", "Person", "DataRole"],
    "Topic": ["BankingActivity", "Risk", "Control", "Data", "Payment", "Compliance"],
    "Provision": ["Definition", "Requirement", "Prohibition", "Permission", "Right", "Exception"]
  },
  "predicates": {
    "applies_to": {"label": "áp dụng cho", "domain": ["LegalDocument", "LegalSection"], "range": ["Actor"]},
    "regulates": {"label": "điều chỉnh", "domain": ["LegalDocument", "LegalSection"], "range": ["Topic"]},
    "requires": {"label": "yêu cầu", "domain": ["Actor", "LegalDocument", "LegalSection"], "range": ["Topic", "Provision"]},
    "prohibits": {"label": "cấm", "domain": ["LegalDocument", "LegalSection"], "range": ["Actor", "Topic", "Provision"]},
    "permits": {"label": "cho phép", "domain": ["LegalDocument", "LegalSection"], "range": ["Actor", "Topic", "Provision"]},
    "has_right": {"label": "có quyền", "domain": ["Actor"], "range": ["Topic", "Provision"]},
    "defines": {"label": "định nghĩa", "domain": ["LegalDocument", "LegalSection"], "range": ["Actor", "Topic"]},
    "references": {"label": "dẫn chiếu", "domain": ["LegalDocument", "LegalSection"], "range": ["LegalDocument", "LegalSection"]},
    "amends": {"label": "sửa đổi", "domain": ["LegalDocument"], "range": ["LegalDocument"]},
    "replaces": {"label": "thay thế", "domain": ["LegalDocument"], "range": ["LegalDocument"]},
    "issued_by": {"label": "ban hành bởi", "domain": ["LegalDocument"], "range": ["Actor"]},
    "mentions": {"label": "đề cập", "domain": ["LegalDocument", "LegalSection"], "range": ["Actor", "Topic"]}
  },
  "concepts": [
    {"id": "state_bank", "type": "Authority", "label": "Ngân hàng Nhà nước", "aliases": ["ngân hàng nhà nước", "nhnn", "state bank of vietnam"]},
    {"id": "government", "type": "Authority", "label": "Chính phủ", "aliases": ["chính phủ"]},
    {"id": "ministry_public_security", "type": "Authority", "label": "Bộ Công an", "aliases": ["bộ công an"]},
    {"id": "credit_institution", "type": "FinancialInstitution", "label": "Tổ chức tín dụng", "aliases": ["tổ chức tín dụng", "tctd"]},
    {"id": "commercial_bank", "type": "FinancialInstitution", "label": "Ngân hàng thương mại", "aliases": ["ngân hàng thương mại"]},
    {"id": "foreign_bank_branch", "type": "FinancialInstitution", "label": "Chi nhánh ngân hàng nước ngoài", "aliases": ["chi nhánh ngân hàng nước ngoài"]},
    {"id": "non_bank_credit_institution", "type": "FinancialInstitution", "label": "Tổ chức tín dụng phi ngân hàng", "aliases": ["tổ chức tín dụng phi ngân hàng", "tổ chức phi ngân hàng"]},
    {"id": "payment_service_provider", "type": "FinancialInstitution", "label": "Tổ chức cung ứng dịch vụ thanh toán", "aliases": ["tổ chức cung ứng dịch vụ thanh toán"]},
    {"id": "payment_intermediary", "type": "FinancialInstitution", "label": "Tổ chức cung ứng dịch vụ trung gian thanh toán", "aliases": ["tổ chức cung ứng dịch vụ trung gian thanh toán", "tổ chức trung gian thanh toán"]},
    {"id": "data_subject", "type": "DataRole", "label": "Chủ thể dữ liệu", "aliases": ["chủ thể dữ liệu"]},
    {"id": "data_controller", "type": "DataRole", "label": "Bên kiểm soát dữ liệu cá nhân", "aliases": ["bên kiểm soát dữ liệu cá nhân", "bên kiểm soát dữ liệu"]},
    {"id": "data_processor", "type": "DataRole", "label": "Bên xử lý dữ liệu cá nhân", "aliases": ["bên xử lý dữ liệu cá nhân", "bên xử lý dữ liệu"]},
    {"id": "internal_control", "type": "Control", "label": "Hệ thống kiểm soát nội bộ", "aliases": ["hệ thống kiểm soát nội bộ", "kiểm soát nội bộ"]},
    {"id": "internal_audit", "type": "Control", "label": "Kiểm toán nội bộ", "aliases": ["kiểm toán nội bộ"]},
    {"id": "risk_management", "type": "Risk", "label": "Quản lý rủi ro", "aliases": ["quản lý rủi ro"]},
    {"id": "risk_provision", "type": "Risk", "label": "Dự phòng rủi ro", "aliases": ["dự phòng rủi ro", "trích lập dự phòng"]},
    {"id": "asset_classification", "type": "Risk", "label": "Phân loại tài sản có", "aliases": ["phân loại tài sản có"]},
    {"id": "personal_data", "type": "Data", "label": "Dữ liệu cá nhân", "aliases": ["dữ liệu cá nhân", "bảo vệ dữ liệu cá nhân"]},
    {"id": "sensitive_personal_data", "type": "Data", "label": "Dữ liệu cá nhân nhạy cảm", "aliases": ["dữ liệu cá nhân nhạy cảm"]},
    {"id": "personal_data_processing", "type": "Data", "label": "Xử lý dữ liệu cá nhân", "aliases": ["xử lý dữ liệu cá nhân"]},
    {"id": "data_subject_consent", "type": "Data", "label": "Sự đồng ý của chủ thể dữ liệu", "aliases": ["sự đồng ý của chủ thể dữ liệu", "đồng ý của chủ thể dữ liệu"]},
    {"id": "payment_account", "type": "Payment", "label": "Tài khoản thanh toán", "aliases": ["tài khoản thanh toán"]},
    {"id": "payment_service", "type": "Payment", "label": "Dịch vụ thanh toán", "aliases": ["dịch vụ thanh toán"]},
    {"id": "payment_intermediation", "type": "Payment", "label": "Dịch vụ trung gian thanh toán", "aliases": ["dịch vụ trung gian thanh toán", "trung gian thanh toán"]},
    {"id": "cashless_payment", "type": "Payment", "label": "Thanh toán không dùng tiền mặt", "aliases": ["thanh toán không dùng tiền mặt"]},
    {"id": "regulatory_sandbox", "type": "BankingActivity", "label": "Cơ chế thử nghiệm có kiểm soát", "aliases": ["cơ chế thử nghiệm có kiểm soát", "sandbox ngân hàng"]},
    {"id": "information_system_security", "type": "Compliance", "label": "An toàn hệ thống thông tin", "aliases": ["an toàn hệ thống thông tin", "an toàn thông tin"]},
    {"id": "scope", "type": "Compliance", "label": "Phạm vi điều chỉnh", "aliases": ["phạm vi điều chỉnh"]},
    {"id": "applicable_subjects", "type": "Compliance", "label": "Đối tượng áp dụng", "aliases": ["đối tượng áp dụng"]},
    {"id": "effective_date", "type": "Compliance", "label": "Hiệu lực thi hành", "aliases": ["hiệu lực thi hành", "có hiệu lực từ"]}
  ],
  "query_intents": {
    "requires": ["phải", "trách nhiệm", "nghĩa vụ", "yêu cầu", "cần làm gì"],
    "prohibits": ["cấm", "không được", "bị cấm"],
    "permits": ["được phép", "cho phép"],
    "has_right": ["quyền", "có quyền"],
    "defines": ["là gì", "định nghĩa", "giải thích từ ngữ"],
    "applies_to": ["áp dụng cho", "đối tượng áp dụng"],
    "amends": ["sửa đổi", "bổ sung"],
    "replaces": ["thay thế", "hết hiệu lực"],
    "references": ["dẫn chiếu", "căn cứ", "liên quan văn bản"]
  }
}
